@model Proyecto_Final_CentroMedico.Pago
@{
}

<link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet" />
<link href="~/css/style_pagos_crud.css" rel="stylesheet" />

<link href="https://cdn.jsdelivr.net/npm/sweetalert2@10.16.6/dist/sweetalert2.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@10.16.6/dist/sweetalert2.min.js"></script>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-8">
            <div class="card border-primary mt-5 rounded-lg">
                <div class="card-header">
                    Editar Pago
                </div>
                <form asp-action="Editar">
                    <div asp-validation-summary="ModelOnly" class="form-control"></div>
                    <input type="hidden" asp-for="IdPago" />
                    <div class="mb-3">
                        <label asp-for="IdUsuario" class="form-label">Usuario</label>
                        <input asp-for="IdUsuario" type="text" class="form-control" aria-describedby="emailHelp">
                        <span asp-validation-for="IdUsuario"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="TotalPagar" class="form-label">Total a Pagar</label>
                        <input asp-for="TotalPagar" type="text" class="form-control" aria-describedby="emailHelp">
                        <span asp-validation-for="TotalPagar"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Detalle" class="form-label">Detalle</label>
                        <input asp-for="Detalle" type="text" class="form-control" aria-describedby="emailHelp">
                        <span asp-validation-for="Detalle"></span>
                    </div>
                    <button type="submit" value="Editar" class="btn btn-primary btn-block">Editar</button>
                </form>
                <div class="mt-3">
                    <a asp-controller="Pagos" asp-action="Index" class="btn btn-editar btn-block">Volver</a>
                </div>
            </div>
        </div>
    </div>
    <br>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
