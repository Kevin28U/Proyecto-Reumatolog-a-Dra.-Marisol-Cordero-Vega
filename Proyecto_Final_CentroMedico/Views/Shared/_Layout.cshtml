<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reumatología Dra Marisol Cordero</title>
    <link href="https://cdn.jsdelivr.net/npm/remixicon@3.4.0/fonts/remixicon.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="~/css/Index.css">
    <link rel="stylesheet" href="~/css/panel.css">
    <link rel="stylesheet" href="~/css/estilo_SeccionInformativa_1.css" media="screen">
    <link rel="stylesheet" href="~/css/estilo_SeccionInformativa_2.css" media="screen">


</head>
<body>


    @if (ViewBag.ShowNavbar != false)
    {
        <nav class="navbar navbar-expand-lg p-4 nav">
            <a class="navbar-brand text-white" asp-area="" asp-controller="Home" asp-action="Index">Reumatología Dra. Marisol Cordero</a>
            <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarNavAltMarkup" aria-controls="navbarNavAltMarkup" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse justify-content-end" id="navbarNavAltMarkup">
                <div class="navbar-nav">
                    <a class="nav-item nav-link text-white active" asp-area="" asp-controller="Home" asp-action="Index">Inicio</a>
                    <a class="nav-item nav-link text-white" asp-area="" asp-controller="Home" asp-action="SeccionInformativa">Acerca de</a>
                    <a class="nav-item nav-link text-white" asp-area="" asp-controller="Cita" asp-action="Index">Citas</a>
                    <a class="nav-item nav-link text-white" asp-area="" asp-controller="Expediente" asp-action="Index">Expedientes</a>
                    <a class="nav-item nav-link text-white" asp-area="" asp-controller="Usuario" asp-action="Index">Panel Administrativo</a>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    }


    @RenderBody()

    @if (ViewBag.ShowFooter != false)
    {

        <footer class="footer row">
            <div class="section__container footer__container">
                <div class="footer__col">
                    <h3>Salud<span>Care</span></h3>
                    <p>
                        Nos sentimos honrados de ser parte de tu camino en el cuidado de la salud y comprometidos a brindar atención compasiva, personalizada y de primera calidad en cada paso del camino.
                    </p>
                    <p>
                        Confía en nosotros tu salud y trabajemos juntos para lograr los mejores resultados posibles para ti y tus seres queridos.
                    </p>
                </div>
                <div class="footer__col">
                    <h4>Acerca de Nosotros</h4>
                    <p>Inicio</p>
                    <p>Acerca de Nosotros</p>
                    <p>Trabaja Con Nosotros</p>
                    <p>Nuestro Blog</p>
                    <p>Términos y Condiciones</p>
                </div>
                <div class="footer__col">
                    <h4>Servicios</h4>
                    <p>Búsqueda de Términos</p>
                    <p>Búsqueda Avanzada</p>
                    <p>Política de Privacidad</p>
                    <p>Proveedores</p>
                    <p>Nuestras Tiendas</p>
                </div>
                <div class="footer__col">
                    <h4>Contacto</h4>
                    <p>
                        <i class="ri-map-pin-2-fill"></i> 123, Calle Principal, San José, Costa Rica
                    </p>
                    <p><i class="ri-mail-fill"></i> DraMarisolCordero@salud.com</p>
                    <p><i class="ri-phone-fill"></i> (+506) 1234-5678</p>
                </div>
            </div>
            <div class="footer__bar">
                <div class="footer__bar__content">
                    <p>Derechos de autor © 2024 Reumatología Dra Marisol Cordero. Todos los derechos reservados.</p>
                    <div class="footer__socials">
                        <span><i class="ri-instagram-line"></i></span>
                        <span><i class="ri-facebook-fill"></i></span>
                        <span><i class="ri-heart-fill"></i></span>
                        <span><i class="ri-twitter-fill"></i></span>
                    </div>
                </div>
            </div>
        </footer>

    }

   

</body>
</html>
