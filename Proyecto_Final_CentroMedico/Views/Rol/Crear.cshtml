@model Proyecto_Final_CentroMedico.Rol
@{
}

<link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet" />
<link href="~/css/style_rol_crud.css" rel="stylesheet" />

<div class="container">
    <div class="row justify-content-center">
        <div class="col-8">
            <div class="card border-primary mt-5 rounded-lg">
                <div class="card-header">
                    Crear Rol
                </div>
                <form asp-action="Crear">
                    <div asp-validation-summary="ModelOnly"></div>
                    <div class="mb-3">
                        <label asp-for="NombreRol" class="form-label">Nombre</label>
                        <input asp-for="NombreRol" type="text" class="form-control" aria-describedby="emailHelp">
                        <span asp-validation-for="NombreRol"></span>
                    </div>
                    <br>
                    <button type="submit" value="Crear" class="btn btn-primary btn-block">Agregar</button>
                </form>
                <div class="mt-3">
                    <a href="~/Rol/Index" class="btn btn-primary btn-block">Volver</a>
                </div>
            </div>
        </div>
    </div>
    <br>
</div>