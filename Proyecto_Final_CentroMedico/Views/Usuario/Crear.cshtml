}

<link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet" />
<link href="~/css/style_usuario_crud.css" rel="stylesheet" />

<div class="container">
    <div class="row justify-content-center">
        <div class="col-8">
            <div class="card border-primary mt-5 rounded-lg">
                <div class="card-header">
                    Crear Usuario
                </div>
                <form>
                    <div class="mb-3">
                        <label for="nombre" class="form-label">Nombre</label>
                        <input type="text" class="form-control" id="nombre" aria-describedby="emailHelp">
                    </div>
                    <div class="mb-3">
                        <label for="primerApellido" class="form-label">Primer Apellido</label>
                        <input type="text" class="form-control" id="primerApellido" aria-describedby="emailHelp">
                    </div>
                    <div class="mb-3">
                        <label for="segundoApellido" class="form-label">Segundo Apellido</label>
                        <input type="text" class="form-control" id="segundoApellido" aria-describedby="emailHelp">
                    </div>
                    <div class="mb-3">
                        <label for="rol" class="form-label">Rol</label>
                        <select class="form-control">
                            <option value="administrador">Administrador</option>
                            <option value="medico">Médico</option>
                            <option value="secretario">Secretario</option>
                            <option value="paciente">Paciente</option>
                        </select>
                    </div>
                    <br>
                    <button type="submit" class="btn btn-primary btn-block">Agregar</button>
                </form>
                <div class="mt-3">
                    <a href="Usuarios.html" class="btn btn-primary btn-block">Volver</a>
                </div>
            </div>
        </div>
    </div>
    <br>
</div>
