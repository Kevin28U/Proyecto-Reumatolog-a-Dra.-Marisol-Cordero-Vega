@model Proyecto_Final_CentroMedico.Rol
@{
}

<link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet" />
<link href="~/css/style_rol_crud.css" rel="stylesheet" />

<link href="https://cdn.jsdelivr.net/npm/sweetalert2@10.16.6/dist/sweetalert2.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@10.16.6/dist/sweetalert2.min.js"></script>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-8">
            <div class="card border-primary mt-5 rounded-lg">
                <div class="card-header">
                    Editar Rol
                </div>
                <form id="editForm" asp-action="Editar">
                    <div asp-validation-summary="ModelOnly"></div>
                    <input type="hidden" asp-for="IdRol" />
                    <div class="mb-3">
                        <label asp-for="NombreRol" class="form-label">Nombre</label>
                        <input type="text" class="form-control" asp-for="NombreRol" aria-describedby="emailHelp">
                        <span asp-validation-for="NombreRol"></span>
                    </div>
                    <br>
                    <button type="submit" value="Editar" class="btn btn-primary btn-block">Editar</button>
                </form>
                <div class="mt-3">
                    <a asp-controller="Rol" asp-action="Index" class="btn btn-editar btn-block">Volver</a>
                </div>
            </div>
        </div>
    </div>
    <br>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>
    $(document).ready(function () {
        $('#editForm').submit(function (e) {
            e.preventDefault(); // prevenir el envío por defecto

            var nombreRol = $('#NombreRol').val().trim();

            if (nombreRol === '') {
                Swal.fire({
                    icon: 'error',
                    title: 'Error!',
                    text: 'El nombre del rol es obligatorio.'
                });
                return false;
            }

            $.ajax({
                type: 'POST',
                url: '@Url.Action("Editar")',
                data: $(this).serialize(),
                success: function (response) {
                    if (response.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Editado!',
                            text: 'El rol ha sido editado con éxito.'
                        }).then(() => {
                            window.location.href = '@Url.Action("Index", "Rol")';
                        });
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Error!',
                            text: response.message || 'No se pudo editar el rol.'
                        });
                    }
                }
            });
        });
    });
</script>
