@model DAL.ViewModels.PagosViewModel


<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard</title>
    <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet">
    <link href="~/css/style_usuario_index.css" rel="stylesheet">
</head>

<body>
    <div class="container-fluid">
        <div class="row">
            <aside class="barra-lateral col-auto p-0">
                <div class="logo my-3">
                    <h2 class="py-4 m-0">Gestion de Pagos</h2>
                </div>
                <nav class="menu d-flex d-sm-block justify-content-center flex-wrap">
                    <a asp-controller="Pagos" asp-action="Index">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-people-fill" viewBox="0 0 16 16">
                            <path d="M7 14s-1 0-1-1 1-4 5-4 5 3 5 4-1 1-1 1zm4-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6m-5.784 6A2.24 2.24 0 0 1 5 13c0-1.355.68-2.75 1.936-3.72A6.3 6.3 0 0 0 5 9c-4 0-5 3-5 4s1 1 1 1zM4.5 8a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5" />
                        </svg>
                        Lista de Pagos
                    </a>
                    <a asp-controller="Pagos" asp-action="Buscar">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-nut-fill" viewBox="0 0 16 16">
                            <path d="M4.58 1a1 1 0 0 0-.868.504l-3.428 6a1 1 0 0 0 0 .992l3.428 6A1 1 0 0 0 4.58 15h6.84a1 1 0 0 0 .868-.504l3.429-6a1 1 0 0 0 0-.992l-3.429-6A1 1 0 0 0 11.42 1zm5.018 9.696a3 3 0 1 1-3-5.196 3 3 0 0 1 3 5.196" />
                        </svg>
                        Buscar Pago
                    </a>
                </nav>
            </aside>

            <main class="main col">
                <div class="container">
                    <div class="row">
                        <div class="col-6 mx-auto">
                            <div class="d-flex flex-column justify-content-center">
                                <div class="d-flex justify-content-center mt-3 mb-5">
                                    <h3 style="font-size:40px" class="pe-3 m-0">Buscar Pago</h3>

                                </div>

                                <form asp-action="Buscar" method="post">
                                    <div class="mb-3">
                                        <label for="IdPago" class="form-label">ID de Pago</label>
                                        <input class="form-control" type="text" id="idBuscar" name="idBuscar" value="" />
                                    </div>
                                    <button type="submit" class="btn btn-editar btn-crear-rol">Buscar Pago</button>
                                </form>

                            </div>
                        </div>
                    </div>
                </div>

                @if (Model != null)
                {
                    <table class="table">
                        <thead>
                            <tr>
                                <th scope="col">ID Pago</th>
                                <th scope="col">Usuario</th>
                                <th scope="col">Total a Pagar</th>
                                <th scope="col">Detalle</th>
                            </tr>
                        </thead>
                        <tbody>
                                <tr>
                                    <th scope="row">@Model.IdPago</th>
                                    <td>@Model.IdUsuarioNavigation.IdUsuario</td>
                                    <td>@Model.TotalPagar</td>
                                    <td>@Model.Detalle</td>
                                </tr>
                        </tbody>
                    </table>


                }

                @{
                    if (ViewBag.datosEncontrados != null && ViewBag.datosEncontrados == false)
                    {
                        <p class="text-danger text-center mt-5" id="mensaje-confirmacion"><strong>¡Pago no encontrado!</strong></p>


                    }

                }

            </main>
        </div>
    </div>

</body>

</html>
