@{

}

<link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet" />
<link href="~/css/style_expedientes_crud.css" rel="stylesheet" />

<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">
            <div class="card border-primary mt-5 rounded-lg">
                <div class="card-header bg-primary text-white text-center rounded-top">
                    <h3 class="mb-0">Crear Expediente</h3>
                </div>
                <div class="card-body">
                    <form>
                        <div class="form-row">
                            <h4>Información del Paciente</h4>
                        </div>
                        <div class="form-row">
                            <div class="form-group col-md-6">
                                <label for="cedula">Cedula</label>
                                <input type="text" class="form-control" id="cedula" placeholder="Ingrese el número de cédula">
                            </div>
                            <div class="form-group col-md-6">
                                <label for="fechaNacimiento">Fecha Nacimiento</label>
                                <input type="date" class="form-control" id="fechaNacimiento" placeholder="Ingrese la fecha de nacimiento">
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="form-group col-md-6">
                                <label for="nombre">Nombre</label>
                                <input type="text" class="form-control" id="nombre" placeholder="Ingrese su nombre">
                            </div>
                            <div class="form-group col-md-6">
                                <label for="primerApellido">Primer Apellido</label>
                                <input type="text" class="form-control" id="primerApellido" placeholder="Ingrese su primer apellido">
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="form-group col-md-6">
                                <label for="segundoApellido">Segundo Apellido</label>
                                <input type="text" class="form-control" id="segundoApellido" placeholder="Ingrese su segundo apellido">
                            </div>
                            <div class="form-group col-md-6">
                                <label for="sexo">Sexo</label>
                                <select class="form-control" id="sexo" asp-items="ViewBag.Sexos">
                                    <option value="">Seleccione el sexo</option>

                                </select>
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="form-group col-md-6">
                                <label for="ocupacion">Ocupación</label>
                                <select class="form-control" id="ocupacion" asp-items="ViewBag.Ocupaciones">
                                    <option value="">Seleccione la ocupación</option>

                                </select>
                            </div>
                            <div class="form-group col-md-6">
                                <label for="edad">Edad</label>
                                <input type="number" class="form-control" id="edad" placeholder="Ingrese su edad">
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="form-group col-md-6">
                                <label for="canton">Cantón</label>
                                <select class="form-control" id="canton" asp-items="ViewBag.Cantones">
                                    <option value="">Seleccione su cantón</option>

                                </select>
                            </div>
                            <div class="form-group col-md-6">
                                <label for="provincia">Provincia</label>
                                <select class="form-control" id="provincia" asp-items="ViewBag.Provincias">
                                    <option value="">Seleccione su provincia</option>

                                </select>
                            </div>
                        </div>
                        <div class="form-group">
                            <label for="direccion">Dirección</label>
                            <input type="text" class="form-control" id="direccion" placeholder="Ingrese su dirección">
                        </div>

                        <div class="form-row">
                            <h4>Antecedentes del Paciente</h4>
                        </div>
                        <div class="form-group">
                            <label for="AGO">Antecedentes Gineco-Obstetricos</label>
                            <textarea rows="8" class="form-control" id="AGO">

                            </textarea>
                        </div>
                        <div class="form-group">
                            <label for="APnoP">Antecedentes Personales No Patológicos</label>
                            <textarea rows="8" class="form-control" id="APnoP">

                            </textarea>
                        </div>
                        <div class="form-group">
                            <label for="APP">Antecedentes Personales Patológicos</label>
                            <textarea rows="8" class="form-control" id="APP">

                            </textarea>
                        </div>
                        <div class="form-group">
                            <label for="AHF">Antecedentes Heredo-familiares</label>
                            <textarea rows="8" class="form-control" id="AHF">

                            </textarea>
                        </div>
                        <div class="form-group">
                            <label for="AQTx">Antecedentes Quirúrgicos y Traumáticos </label>
                            <textarea rows="8" class="form-control" id="AQTx">

                            </textarea>
                        </div>

                        <button type="submit" class="btn btn-primary btn-block rounded-pill">Guardar</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
    <br></br>
</div>
