@model IEnumerable<Proyecto_Final_CentroMedico.Bitacora>
<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard</title>
    <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet">
    <link href="~/css/style_expedientes_index.css" rel="stylesheet">
</head>

<body>
    <div class="container-fluid">
        <div class="row">
            <aside class="barra-lateral col-auto p-0">
                <div class="logo my-3">
                    <h2 class="py-4 m-0">Dashboard</h2>
                </div>
                <nav class="menu d-flex d-sm-block justify-content-center flex-wrap">
                    <a asp-controller="Expediente" asp-action="Index">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-archive-fill" viewBox="0 0 16 16">
                            <path d="M12.643 15C13.979 15 15 13.845 15 12.5V5H1v7.5C1 13.845 2.021 15 3.357 15zM5.5 7h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1 0-1M.8 1a.8.8 0 0 0-.8.8V3a.8.8 0 0 0 .8.8h14.4A.8.8 0 0 0 16 3V1.8a.8.8 0 0 0-.8-.8z" />
                        </svg>
                        Buscar Expediente
                    </a>
                    <a asp-controller="Expediente" asp-action="Crear">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-file-earmark-plus-fill" viewBox="0 0 16 16">
                            <path d="M9.293 0H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2V4.707A1 1 0 0 0 13.707 4L10 .293A1 1 0 0 0 9.293 0M9.5 3.5v-2l3 3h-2a1 1 0 0 1-1-1M8.5 7v1.5H10a.5.5 0 0 1 0 1H8.5V11a.5.5 0 0 1-1 0V9.5H6a.5.5 0 0 1 0-1h1.5V7a.5.5 0 0 1 1 0" />
                        </svg>
                        Crear Expediente
                    </a>
                    <a asp-controller="Bitacora" asp-action="Index">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-journal-check" viewBox="0 0 16 16">
                            <path d="M12.156 2.156A.5.5 0 0 0 12 2H4a.5.5 0 0 0-.5.5V3h9V2.5a.5.5 0 0 0-.344-.474zM13 4V3a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v1h1V3a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v1h1V4a1 1 0 0 0-1-1H5a1 1 0 0 0-1 1v1H3V5a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v1h1z" />
                            <path d="M12.5 7.5a.5.5 0 0 0-1 0V8H9.5a.5.5 0 0 0 0 1H11v1.5a.5.5 0 0 0 1 0V9h1V7a.5.5 0 0 0-1 0" />
                            <path d="M6 10.5a.5.5 0 0 0-1 0v2a.5.5 0 0 0 1 0v-2z" />
                        </svg>
                        Bitácoras
                    </a>
                    <a asp-controller="Expediente" asp-action="Dashboard">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-bar-chart-line-fill" viewBox="0 0 16 16">
                            <path d="M11 2a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v12h.5a.5.5 0 0 1 0 1H.5a.5.5 0 0 1 0-1H1v-3a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v3h1V7a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v7h1z" />
                        </svg>
                        Visualización de Datos
                    </a>
                </nav>
            </aside>

            <main class="main col">
                <div class="container">
                    <div class="row">
                        <div class="col-6 mx-auto">
                            <div class="d-flex flex-column justify-content-center">
                                <div class="d-flex justify-content-center mt-3 mb-5">
                                    <h3 style="font-size: 40px" class="pe-3 m-0">Buscar Bitacora</h3>
                                </div>

                                <form asp-action="Buscar" method="post">
                                    <div class="mb-3">
                                        <label for="cedula" class="form-label">Número de Cédula</label>
                                        <input class="form-control" type="text" id="cedulaBuscar" name="cedulaBuscar" value="" />
                                    </div>
                                    <button type="submit" class="btn btn-editar btn-block rounded-pill">Buscar Bitacora</button>
                                </form>

                            </div>
                        </div>
                    </div>
                </div>

                <div class="container">
                    <div class="row">
                        <div class="col">
                            <h2>Bitácoras del Expediente</h2>
                            <a class="btn btn-editar btn-block rounded-pill" asp-controller="Bitacora" asp-action="Crear">Agregar Bitácora</a>

                            @if (ViewBag.datosEncontrados ?? false)
                            {
                                <div class="table-responsive">
                                    <table class="table mt-3">
                                        <thead>
                                            <tr>
                                                <th scope="col">ID Bitácora</th>
                                                <th scope="col">Sintomatología</th>
                                                <th scope="col">Evolución</th>
                                                <th scope="col">Cambios en Tratamiento</th>
                                                <th scope="col">Acciones</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var item in Model)
                                            {
                                                <tr>
                                                    <td>@item.IdBitacora</td>
                                                    <td>@item.Sintomatologia</td>
                                                    <td>@item.Evolucion</td>
                                                    <td>@item.CambiosTratamiento</td>
                                                    <td>
                                                        <a class="btn btn-editar" asp-controller="Bitacora" asp-action="Editar" asp-route-id="@item.IdBitacora">Editar</a>
                                                        <a class="btn btn-eliminar" asp-controller="Bitacora" asp-action="Eliminar" asp-route-id="@item.IdBitacora">Eliminar</a>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <p>No se encontraron bitácoras para el expediente buscado.</p>
                            }
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
            crossorigin="anonymous"></script>
</body>

</html>
