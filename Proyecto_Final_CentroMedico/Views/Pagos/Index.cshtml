        <main class="main col">
            <div class="container-fluid">
                <!-- Page Heading -->
                <div class="d-sm-flex align-items-center justify-content-between mb-4 header-section">
                    <h1 class="h3 mb-0 text-gray-800 text-center">Gestión de Pagos</h1>
                </div>
                <p>
                    <a class="btn btn-editar btn-crear-rol" asp-controller="Pagos" asp-action="Crear">Agregar un nuevo pago</a>
                </p>

                <!-- Formulario de búsqueda -->
                <form asp-action="Buscar" method="post" class="form-inline mb-4">
                    <div class="form-group mr-2">
                        <input type="number" name="idBuscar" class="form-control" placeholder="ID del Pago" />
                    </div>
                    <button type="submit" class="btn btn-editar btn-crear-rol">Buscar</button>
                    <a class="btn btn-editar btn-crear-rol" asp-controller="Pagos" asp-action="Index">Ver lista completa</a>
                </form>

                <table class="table">
                    <thead>
                        <tr>
                            <th scope="col">Usuario</th>
                            <th scope="col">Total a Pagar</th>
                            <th scope="col">Detalle</th>
                            <th scope="col">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    @Html.DisplayFor(modelItem => item.IdUsuarioNavigation.IdUsuario)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.TotalPagar)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.Detalle)
                                </td>
                                <td>
                                    <a class="btn btn-editar" asp-controller="Pagos" asp-action="Editar" asp-route-id="@item.IdPago">Editar</a>
                                    <a class="btn btn-eliminar" asp-controller="Pagos" asp-action="Eliminar" asp-route-id="@item.IdPago">Eliminar</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </main>
    </div>
</div>

